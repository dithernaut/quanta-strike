#!/bin/bash
#
# Patch .ttf files in an input directory with Nerd Font icons.
#
# Usage: ./scripts/generate-nerd-fonts <input-dir> [output-dir] [family ...]
#   input-dir   directory of built .ttf files (e.g. build/ttf/quanta-strike)
#   output-dir  where to write patched fonts (default: "<input-dir>-nerd")
#   family ...  optional family names to patch (e.g. quanta-strike-8).
#               If omitted, every .ttf in input-dir is patched.
#
# Each "<family>-<style>.ttf" becomes "<family>-nerd-<style>.ttf" with its own
# family name "<family>-nerd", so all strikes share one output folder while
# staying distinct families.

# Resolve our own location so the helper script and the vendored patcher are
# found regardless of the caller's cwd. Input/output dirs stay caller-relative.
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
REPO_ROOT="$( cd "$SCRIPT_DIR/.." && pwd )"

INPUT_DIR="$1"
if [ -z "$INPUT_DIR" ]; then
    echo "Usage: $0 <input-dir> [output-dir] [family ...]"
    echo "Example: $0 build/ttf/quanta-strike"
    echo "Example: $0 build/ttf/quanta-strike build/ttf/quanta-strike-nerd quanta-strike-8 quanta-strike-16"
    exit 1
fi
INPUT_DIR="${INPUT_DIR%/}"

# Remaining args: optional output-dir, then optional family filters.
# output-dir is detected as the first arg that is not a known family prefix
# of an input font — or explicitly a path ending in -nerd / an existing dir.
shift
OUTPUT_DIR=""
FAMILY_FILTERS=()

if [ $# -gt 0 ]; then
    # If first remaining arg looks like an output directory (exists as dir, or
    # ends with -nerd, or contains a slash), treat it as OUTPUT_DIR.
    case "$1" in
        *-nerd|*/|*/*)
            OUTPUT_DIR="${1%/}"
            shift
            ;;
        *)
            if [ -d "$1" ]; then
                OUTPUT_DIR="${1%/}"
                shift
            fi
            ;;
    esac
fi

while [ $# -gt 0 ]; do
    FAMILY_FILTERS+=("$1")
    shift
done

OUTPUT_DIR="${OUTPUT_DIR:-${INPUT_DIR}-nerd}"

if [ ! -d "$INPUT_DIR" ]; then
    echo "Error: input directory not found: $INPUT_DIR"
    exit 1
fi
if [ ! -f "$REPO_ROOT/patcher/font-patcher" ]; then
    echo "Error: font-patcher script not found in patcher directory"
    exit 1
fi

mkdir -p "$OUTPUT_DIR"

# Known style tokens, longest first, so we can split "<family>-<style>".
STYLES="bolditalic blackitalic bold black italic light medium semibold thin regular"

shopt -s nullglob
fonts=("$INPUT_DIR"/*.ttf)
if [ ${#fonts[@]} -eq 0 ]; then
    echo "No .ttf files found in $INPUT_DIR"
    exit 1
fi

# Filter to selected families when provided
if [ ${#FAMILY_FILTERS[@]} -gt 0 ]; then
    filtered=()
    for font_file in "${fonts[@]}"; do
        filename="$(basename "$font_file")"
        base_name="${filename%.*}"
        family="$base_name"
        for s in $STYLES; do
            case "$base_name" in
                *-"$s")
                    family="${base_name%-$s}"
                    break
                    ;;
            esac
        done
        for want in "${FAMILY_FILTERS[@]}"; do
            if [ "$family" = "$want" ]; then
                filtered+=("$font_file")
                break
            fi
        done
    done
    fonts=("${filtered[@]}")
    if [ ${#fonts[@]} -eq 0 ]; then
        echo "No matching .ttf files for families: ${FAMILY_FILTERS[*]}"
        exit 1
    fi
    echo "Patching ${#fonts[@]} font(s) for: ${FAMILY_FILTERS[*]}"
fi

for font_file in "${fonts[@]}"; do
    filename="$(basename "$font_file")"
    base_name="${filename%.*}"

    # Split base_name into <family>-<style>
    family="$base_name"
    style="regular"
    for s in $STYLES; do
        case "$base_name" in
            *-"$s")
                family="${base_name%-$s}"
                style="$s"
                break
                ;;
        esac
    done

    nerd_family="${family}-nerd"
    output_name="${nerd_family}-${style}.ttf"
    desired="$OUTPUT_DIR/$output_name"

    echo "Processing $filename  ->  $output_name"

    before=$(ls "$OUTPUT_DIR"/*.ttf 2>/dev/null)

    fontforge --script "$REPO_ROOT/patcher/font-patcher" \
        --careful \
        --mono \
        -q \
        --simple \
        --complete \
        --makegroups 0 \
        --outputdir "$OUTPUT_DIR" \
        "$font_file"

    if [ $? -ne 0 ]; then
        echo "  Error patching $filename"
        continue
    fi

    # Locate every file font-patcher just wrote (name varies by version / flags).
    # Normalize to the hyphenated "<family>-nerd-<style>.ttf" and drop leftovers
    # like "<family>nerd-<style>.ttf".
    new_files=()
    for f in "$OUTPUT_DIR"/*.ttf; do
        [ -f "$f" ] || continue
        case "$before" in
            *"$f"*) : ;;          # pre-existing
            *) new_files+=("$f") ;;
        esac
    done

    patched=""
    for f in "${new_files[@]}"; do
        if [ "$f" = "$desired" ]; then
            patched="$f"
            break
        fi
        patched="$f"
    done
    if [ -z "$patched" ] && [ -f "$OUTPUT_DIR/${family}nerd-${style}.ttf" ]; then
        patched="$OUTPUT_DIR/${family}nerd-${style}.ttf"
    fi

    if [ -n "$patched" ] && [ -f "$patched" ]; then
        if [ "$patched" != "$desired" ]; then
            mv -f "$patched" "$desired"
        fi
        # Drop any other newly written duplicates
        for f in "${new_files[@]}"; do
            if [ "$f" != "$desired" ] && [ -f "$f" ]; then
                rm -f "$f"
            fi
        done
    fi

    # Always remove the unhyphenated "familynerd-style" leftover if present.
    rm -f "$OUTPUT_DIR/${family}nerd-${style}.ttf"

    if [ -f "$desired" ]; then
        # Give it a clean family name, preserving copyright/version/license.
        fontforge -lang=py -script "$SCRIPT_DIR/rename-family.py" "$desired" "$nerd_family" "$style" >/dev/null 2>&1
        echo "  Successfully generated $output_name"
    else
        echo "  Could not locate patched output for $filename"
    fi
done

echo "All fonts have been processed!"
