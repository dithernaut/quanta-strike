#!/bin/bash
#
# Batch Nerd Font generation for the consolidated build layout.
#
# Patches every strike in build/ttf/quanta-strike/ into
# build/ttf/quanta-strike-nerd/ (all strikes share the folder, each keeps its
# own "<strike>-nerd" family).

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR"

INPUT_DIR="./build/ttf/quanta-strike"

if [ ! -d "$INPUT_DIR" ]; then
    echo "Error: $INPUT_DIR not found. Run the metadata patcher / build.sh first."
    exit 1
fi

./scripts/generate-nerd-fonts "$INPUT_DIR"
